NODE_ENV=development
PORT=3000
FRONTEND_PORT=3001
HELMET_ENABLED=true
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=100
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

DATABASE_URL=postgresql://energy:energy@localhost:5432/energy_bill?schema=public

JWT_ACCESS_SECRET=dev-access-secret
JWT_REFRESH_SECRET=dev-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=energy-bill-ai-parser
JWE_SECRET=dev-jwe-secret-with-at-least-32-chars
DEFAULT_ADMIN_EMAIL=admin@local.test
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@123456
STORAGE_DRIVER=localstack
S3_REGION=us-east-1
S3_BUCKET=energy-bills
S3_ENDPOINT=http://localhost:4566
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_FORCE_PATH_STYLE=true

# Desafio default: Gemini com suporte nativo a PDF.
OPEN_SOURCE_IA=false
LLM_PROVIDER=gemini

OLLAMA_BASE_URL=http://localhost:11434
# Modelo usado na API e no serviço docker `ollama-init`
OLLAMA_MODEL=llama3.2-vision
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
PDF_MAX_FILE_SIZE_MB=50
ROLLBACK_ON_INVOICE_FAILURE=true
LOGS=true

# Optional cloud providers (when OPEN_SOURCE_IA=false)
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Frontend (Next.js)
BACKEND_API_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:3000
