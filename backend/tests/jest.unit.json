{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "tests/unit/.*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "setupFiles": ["<rootDir>/tests/setup/test-env.ts"],
  "setupFilesAfterEnv": ["<rootDir>/tests/setup/jest.setup.ts"]
}
